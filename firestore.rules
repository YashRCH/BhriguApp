rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function verifiedEmail() {
      // TODO: Revert this to `return request.auth.token.email_verified == true;` for production
      return true;
    }

    function validAiResponseLanguage(value) {
      return value in ['english', 'hinglish'];
    }

    function validUsername(value) {
      return value is string
        && value.matches('^[a-z0-9_]{3,24}$');
    }

    function validFcmTokens(value) {
      return value is list
        && value.size() <= 20
        && validOptionalFcmTokenAt(value, 0)
        && validOptionalFcmTokenAt(value, 1)
        && validOptionalFcmTokenAt(value, 2)
        && validOptionalFcmTokenAt(value, 3)
        && validOptionalFcmTokenAt(value, 4)
        && validOptionalFcmTokenAt(value, 5)
        && validOptionalFcmTokenAt(value, 6)
        && validOptionalFcmTokenAt(value, 7)
        && validOptionalFcmTokenAt(value, 8)
        && validOptionalFcmTokenAt(value, 9)
        && validOptionalFcmTokenAt(value, 10)
        && validOptionalFcmTokenAt(value, 11)
        && validOptionalFcmTokenAt(value, 12)
        && validOptionalFcmTokenAt(value, 13)
        && validOptionalFcmTokenAt(value, 14)
        && validOptionalFcmTokenAt(value, 15)
        && validOptionalFcmTokenAt(value, 16)
        && validOptionalFcmTokenAt(value, 17)
        && validOptionalFcmTokenAt(value, 18)
        && validOptionalFcmTokenAt(value, 19);
    }

    function validOptionalFcmTokenAt(value, index) {
      return value.size() <= index || (
        value[index] is string
        && value[index].size() > 0
        && value[index].size() <= 4096
      );
    }

    function validOptionalCoordinate(value, min, max) {
      return value == null || (value is number && value >= min && value <= max);
    }

    function validUserProfileCreate() {
      return request.resource.data.keys().hasOnly([
          'name',
          'dob',
          'timeOfBirth',
          'placeOfBirth',
          'latitude',
          'longitude',
          'aiResponseLanguage',
          'username',
          'usernameLower',
          'onboardingComplete',
          'createdAt',
        ])
        && request.resource.data.keys().hasAll([
          'name',
          'dob',
          'timeOfBirth',
          'placeOfBirth',
          'aiResponseLanguage',
          'username',
          'usernameLower',
          'onboardingComplete',
          'createdAt',
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 120
        && request.resource.data.dob is string
        && request.resource.data.dob.size() >= 10
        && request.resource.data.dob.size() <= 40
        && request.resource.data.timeOfBirth is string
        && request.resource.data.timeOfBirth.size() <= 20
        && request.resource.data.placeOfBirth is string
        && request.resource.data.placeOfBirth.size() > 0
        && request.resource.data.placeOfBirth.size() <= 200
        && (
          !request.resource.data.keys().hasAny(['latitude'])
          || validOptionalCoordinate(request.resource.data.latitude, -90, 90)
        )
        && (
          !request.resource.data.keys().hasAny(['longitude'])
          || validOptionalCoordinate(request.resource.data.longitude, -180, 180)
        )
        && validAiResponseLanguage(request.resource.data.aiResponseLanguage)
        && validUsername(request.resource.data.username)
        && request.resource.data.usernameLower == request.resource.data.username
        && request.resource.data.onboardingComplete == false
        && request.resource.data.createdAt is string
        && request.resource.data.createdAt.size() <= 40;
    }

    function validUserProfileUpdate() {
      return (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'aiResponseLanguage',
        ])
        && validAiResponseLanguage(request.resource.data.aiResponseLanguage)
      ) || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'onboardingComplete',
          'updatedAt',
        ])
        && resource.data.onboardingComplete == false
        && request.resource.data.onboardingComplete == true
        && request.resource.data.updatedAt is string
        && request.resource.data.updatedAt.size() <= 40
      ) || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'fcmTokens',
        ])
        && validFcmTokens(request.resource.data.fcmTokens)
      );
    }

    function validAiReport() {
      return request.resource.data.keys().hasOnly([
          'userId',
          'feature',
          'contentId',
          'contentPreview',
          'reason',
          'optionalComment',
          'createdAt',
          'status',
          'platform',
          'appVersion',
        ])
        && request.resource.data.keys().hasAll([
          'userId',
          'feature',
          'contentId',
          'contentPreview',
          'reason',
          'createdAt',
          'status',
          'platform',
        ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.feature in [
          'chat',
          'tarot',
          'geomancy',
          'match',
          'horoscope',
          'circle',
          'connection',
        ]
        && request.resource.data.contentId is string
        && request.resource.data.contentId.size() > 0
        && request.resource.data.contentId.size() <= 160
        && request.resource.data.contentPreview is string
        && request.resource.data.contentPreview.size() > 0
        && request.resource.data.contentPreview.size() <= 503
        && request.resource.data.reason in [
          'Offensive or hateful',
          'Sexual content',
          'Harassment or bullying',
          'Self-harm or dangerous advice',
          'False or misleading',
          'Other',
        ]
        && request.resource.data.status == 'open'
        && request.resource.data.createdAt == request.time
        && request.resource.data.platform in [
          'android',
          'ios',
          'macos',
          'windows',
          'linux',
          'fuchsia',
        ]
        && (
          !request.resource.data.keys().hasAny(['optionalComment'])
          || (
            request.resource.data.optionalComment is string
            && request.resource.data.optionalComment.size() <= 300
          )
        )
        && (
          !request.resource.data.keys().hasAny(['appVersion'])
          || (
            request.resource.data.appVersion is string
            && request.resource.data.appVersion.size() <= 80
          )
        );
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && verifiedEmail() && validUserProfileCreate();
      allow update: if isOwner(userId) && verifiedEmail() && validUserProfileUpdate();
      allow delete: if false;
    }

    match /public_profiles/{userId} {
      allow read: if signedIn();
      allow create, update, delete: if false;
    }

    match /usernames/{username} {
      allow get: if signedIn();
      allow list, write: if false;
    }

    match /invites/{inviteId} {
      allow read, write: if false;
    }

    match /connections/{connectionId} {
      allow read: if signedIn()
        && resource.data.memberIds is list
        && request.auth.uid in resource.data.memberIds;
      allow create, update, delete: if false;

      match /compatibility/{readingId} {
        allow read: if signedIn()
          && get(/databases/$(database)/documents/connections/$(connectionId)).data.memberIds is list
          && request.auth.uid in get(/databases/$(database)/documents/connections/$(connectionId)).data.memberIds;
        allow create, update, delete: if false;
      }

      match /daily_energy/{dateId} {
        allow read: if signedIn()
          && get(/databases/$(database)/documents/connections/$(connectionId)).data.memberIds is list
          && request.auth.uid in get(/databases/$(database)/documents/connections/$(connectionId)).data.memberIds;
        allow create, update, delete: if false;
      }
    }

    match /users/{userId}/chat/{messageId} {
      allow read: if isOwner(userId);
      allow create, update, delete: if isOwner(userId) && verifiedEmail();
    }

    match /users/{userId}/horoscopes/{dateId} {
      allow read: if isOwner(userId);
      allow create, update, delete: if false;
    }

    match /users/{userId}/rewards/{rewardId} {
      allow read: if isOwner(userId);
      allow create, update, delete: if false;
    }

    match /users/{userId}/follow_up_contexts/{contextId} {
      allow read: if isOwner(userId);
      allow create, update, delete: if isOwner(userId) && verifiedEmail();
    }

    match /users/{userId}/connections/{otherUserId} {
      allow read: if isOwner(userId);
      allow create, update, delete: if false;
    }

    match /users/{userId}/tarot_readings/{readingId} {
      allow read: if isOwner(userId);
      allow create, update, delete: if isOwner(userId) && verifiedEmail();
    }

    match /users/{userId}/geomancy_readings/{readingId} {
      allow read: if isOwner(userId);
      allow create, update, delete: if isOwner(userId) && verifiedEmail();
    }

    match /users/{userId}/partner_matches/{matchId} {
      allow read: if isOwner(userId);
      allow create, update, delete: if isOwner(userId) && verifiedEmail();
    }

    match /users/{userId}/partner_match_readings/{readingId} {
      allow read: if isOwner(userId);
      allow create, update, delete: if isOwner(userId) && verifiedEmail();
    }

    match /users/{userId}/match_readings/{readingId} {
      allow read: if isOwner(userId);
      allow create, update, delete: if isOwner(userId) && verifiedEmail();
    }

    match /users/{userId}/compatibility_readings/{readingId} {
      allow read: if isOwner(userId);
      allow create, update, delete: if isOwner(userId) && verifiedEmail();
    }

    match /users/{userId}/usage/{usageId} {
      allow read: if isOwner(userId);
      allow create, update, delete: if false;
    }

    match /users/{userId}/entitlements/{entitlementId} {
      allow read: if isOwner(userId);
      allow create, update, delete: if false;
    }

    match /users/{userId}/wallet/{walletId} {
      allow read: if isOwner(userId);
      allow create, update, delete: if false;
    }

    match /users/{userId}/quota/{quotaId} {
      allow read: if isOwner(userId);
      allow create, update, delete: if false;
    }

    match /users/{userId}/purchases/{purchaseId} {
      allow read: if isOwner(userId);
      allow create, update, delete: if false;
    }

    match /users/{userId}/owlCompanion/{docId} {
      allow read, create, update: if isOwner(userId);
      allow delete: if false;
    }

    match /users/{userId}/aiReadingCache/{cacheId} {
      allow read, write: if false;
    }

    match /aiReports/{reportId} {
      allow create: if signedIn() && verifiedEmail() && validAiReport();
      allow read, update, delete: if false;
    }

    match /book_knowledge/{docId} {
      allow read: if false;
      allow write: if false;
    }

    match /tarot_knowledge/{docId} {
      allow read: if false;
      allow write: if false;
    }

    match /compatibility_knowledge/{docId} {
      allow read: if false;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
